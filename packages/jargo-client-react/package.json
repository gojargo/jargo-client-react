{
  "name": "@gojargo/jargo-client-react",
  "version": "0.1.0",
  "description": "Classic-WebRTC + RTVI browser client for jargo voice servers, with React bindings.",
  "license": "BSD-2-Clause",
  "author": "the jargo authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gojargo/jargo-client-react.git"
  },
  "keywords": ["jargo", "webrtc", "rtvi", "voice-ai", "react"],
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
