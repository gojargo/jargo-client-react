# Copy to .env.local and fill in.

# jargo server base URL.
#  - local:  http://localhost:8080
#  - k8s:    https://jargo.example.com
NEXT_PUBLIC_JARGO_URL=http://localhost:8080

# Optional device/beneficiary id (selects the profile on the server).
NEXT_PUBLIC_JARGO_DEVICE_ID=web-demo

# TURN relay — REQUIRED when the server runs in Kubernetes (media can't reach a
# pod directly). Leave blank for a localhost server. The URL host is the coturn
# public IP injected at deploy time.
NEXT_PUBLIC_JARGO_TURN_URL=
NEXT_PUBLIC_JARGO_TURN_USERNAME=jargo
NEXT_PUBLIC_JARGO_TURN_CREDENTIAL=your-turn-credential
